# =============================================
# MVS Foundation — Environment Variables
# Railway/Render pe yeh sab set karna hoga
# =============================================

# MySQL Database (Railway ya PlanetScale se milega)
DATABASE_URL=mysql+pymysql://user:password@host:3306/mvs_foundation

# JWT Secret Key (koi bhi random string — 32+ characters)
SECRET_KEY=mvs-foundation-super-secret-key-change-this-in-production-2025

# Token expiry (hours mein)
ACCESS_TOKEN_EXPIRE_HOURS=24

# App settings
APP_NAME=MVS Foundation CRM
APP_VERSION=1.0.0
DEBUG=False

# CORS — Frontend ka URL yahan daalo
FRONTEND_URL=*
